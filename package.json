{
  "name": "conversion-repair-word",
  "version": "0.1.0",
  "description": "A free, open-source Microsoft Word add-in that repairs PDF-to-Word conversion damage in the browser. No content leaves the machine.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "certs": "office-addin-dev-certs install",
    "validate": "office-addin-manifest validate manifest/manifest.xml",
    "start": "office-addin-debugging start manifest/manifest.xml",
    "stop": "office-addin-debugging stop manifest/manifest.xml"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@xmldom/xmldom": "^0.9.6",
    "@types/office-js": "^1.0.400",
    "office-addin-debugging": "^6.1.1",
    "office-addin-dev-certs": "^2.0.9",
    "office-addin-manifest": "^2.1.5",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
