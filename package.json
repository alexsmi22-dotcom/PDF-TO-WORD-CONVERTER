{
  "name": "conversion-repair-word",
  "version": "0.1.0",
  "description": "A free, open-source Microsoft Word add-in that repairs PDF-to-Word conversion damage in the browser. No content leaves the machine.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.9.6",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/office-js": "^1.0.400",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
